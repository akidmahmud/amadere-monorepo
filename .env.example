NODE_ENV=development
PORT=3000
DATABASE_URL=postgresql://amader:amader@localhost:5433/amader

# JWT secrets — generate distinct random values per environment, e.g.
# `node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"`
ADMIN_JWT_ACCESS_SECRET=
ADMIN_JWT_REFRESH_SECRET=
CUSTOMER_JWT_ACCESS_SECRET=
CUSTOMER_JWT_REFRESH_SECRET=

# One-time super admin seed (see packages/db/prisma/seed.ts)
SUPER_ADMIN_EMAIL=
SUPER_ADMIN_PASSWORD=

# Cloudflare R2 (S3-compatible) — optional until credentials arrive; media
# upload endpoints fail until these are set, everything else works without them.
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_PUBLIC_BASE_URL=
