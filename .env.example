NODE_ENV=development
PORT=3000
DATABASE_URL=postgresql://amader:amader@localhost:5433/amader

# Comma-separated origins allowed to call this API from a browser (storefront
# search, cart, etc. are client-fetched, not server-proxied). Defaults to
# localhost:3001/3002 if unset — in production this MUST be set to the
# real storefront domain(s), e.g. https://amadere.com, or every browser-side
# request gets silently blocked by CORS ("NetworkError"/"Failed to fetch",
# no server-side error at all).
CORS_ORIGINS=

# JWT secrets — generate distinct random values per environment, e.g.
# `node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"`
ADMIN_JWT_ACCESS_SECRET=
ADMIN_JWT_REFRESH_SECRET=
CUSTOMER_JWT_ACCESS_SECRET=
CUSTOMER_JWT_REFRESH_SECRET=

# One-time super admin seed (see packages/db/prisma/seed.ts)
SUPER_ADMIN_EMAIL=
SUPER_ADMIN_PASSWORD=

# Cloudflare R2 (S3-compatible) — optional until credentials arrive; media
# upload endpoints fail until these are set, everything else works without them.
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_PUBLIC_BASE_URL=

# Google OAuth Client ID (Web application type, from Google Cloud Console) —
# used to verify the ID token the storefront's Google sign-in button gets
# client-side. No client secret needed for this flow.
GOOGLE_CLIENT_ID=

# SMTP — optional until set; every email send (cart-abandonment campaigns,
# admin 2FA login codes) fails silently (logged as a warning, nothing
# crashes) until these are filled in with a real mail provider's details.
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
