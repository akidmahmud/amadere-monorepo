# Base URL of the NestJS backend API (apps/backend), no trailing slash.
# apps/backend also defaults to port 3000 (root .env PORT=3000) — the web
# app's own dev/start scripts pin it to -p 3001 for exactly this reason. If
# this ever points at the frontend's own port instead of the backend's, every
# server-side API call silently loops back into the frontend and 404s.
NEXT_PUBLIC_API_BASE_URL=http://localhost:3000

# Shared secret the backend must send as `X-Revalidate-Secret` when calling
# POST /api/revalidate (on-demand ISR revalidation — see AGENTS.web.md §14).
REVALIDATE_SECRET=change-me
