generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// =========================================================================
// B1 — Phase 1 spine. Scope follows AGENTS.md §6/§8 (B1) exactly.
// Payment/Shipment/FAQ tables are deliberately deferred to B6/B7/B3 — they're
// additive migrations on top of this spine, not part of it.
// =========================================================================

enum Locale {
  EN
  BN
}

// ---------------------------------------------------------------------
// Shared / cross-cutting
// ---------------------------------------------------------------------

// Generic key-value store so feature flags (e.g. multi_brand_enabled) and
// tunables never require a migration to change (AGENTS.md §7).
model Setting {
  key       String   @id
  value     Json
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("settings")
}

enum SeoEntityType {
  PRODUCT
  CATEGORY
  BRAND
  TAG
  PRODUCT_BUNDLE
  BLOG_POST
  BLOG_CATEGORY
  PAGE
  COLLECTION
}

// Uniform SEO surface for every public entity (AGENTS.md §5/§9) so new
// entity types inherit SEO/sitemap support for free instead of bespoke columns.
model SeoMeta {
  id                 Int           @id @default(autoincrement())
  entityType         SeoEntityType @map("entity_type")
  entityId           Int           @map("entity_id")
  locale             Locale
  title              String?
  description        String?
  canonicalUrl       String?       @map("canonical_url")
  robots             String        @default("index,follow")
  ogTitle            String?       @map("og_title")
  ogDescription      String?       @map("og_description")
  ogImageUrl         String?       @map("og_image_url")
  structuredDataType String?       @map("structured_data_type")
  createdAt          DateTime      @default(now()) @map("created_at")
  updatedAt          DateTime      @updatedAt @map("updated_at")

  @@unique([entityType, entityId, locale])
  @@map("seo_meta")
}

// Backs the 301 redirect manager and the B12 migration's old->new URL map.
model Redirect {
  id         Int      @id @default(autoincrement())
  fromPath   String   @unique @map("from_path")
  toPath     String   @map("to_path")
  statusCode Int      @default(301) @map("status_code")
  isActive   Boolean  @default(true) @map("is_active")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@map("redirects")
}

enum MediaType {
  IMAGE
  VIDEO
}

// Real asset registry (R2 URLs) instead of the old app's raw path strings,
// so galleries/videos are referenced by id and reusable across entities.
model Media {
  id        Int       @id @default(autoincrement())
  url       String
  type      MediaType
  altText   String?   @map("alt_text")
  width     Int?
  height    Int?
  createdAt DateTime  @default(now()) @map("created_at")

  productMedia ProductMedia[]

  @@map("media")
}

// Every admin/staff write records here (AGENTS.md §4.2). adminUserId is
// nullable only for system/automated actions (e.g. scheduled jobs).
model AuditLog {
  id          Int      @id @default(autoincrement())
  adminUserId Int?     @map("admin_user_id")
  action      String
  entityType  String   @map("entity_type")
  entityId    Int?     @map("entity_id")
  entityLabel String?  @map("entity_label")
  changes     Json?
  ipAddress   String?  @map("ip_address")
  userAgent   String?  @map("user_agent")
  createdAt   DateTime @default(now()) @map("created_at")

  adminUser AdminUser? @relation(fields: [adminUserId], references: [id], onDelete: SetNull)

  @@index([entityType, entityId])
  @@map("audit_logs")
}

// ---------------------------------------------------------------------
// Admin / Staff auth + RBAC (AGENTS.md §4.2 — build all of this now)
// ---------------------------------------------------------------------

enum AdminUserStatus {
  ACTIVE
  DISABLED
}

model AdminUser {
  id               Int             @id @default(autoincrement())
  email            String          @unique
  passwordHash     String          @map("password_hash")
  firstName        String          @map("first_name")
  lastName         String          @map("last_name")
  phone            String?
  avatarUrl        String?         @map("avatar_url")
  isSuperAdmin     Boolean         @default(false) @map("is_super_admin")
  status           AdminUserStatus @default(ACTIVE)
  twoFactorEnabled Boolean         @default(false) @map("two_factor_enabled")
  // PRD §3.12 IP restriction hook: empty = unrestricted. Enforcement is B11.
  allowedIps       String[]        @map("allowed_ips")
  lastLoginAt      DateTime?       @map("last_login_at")
  createdAt        DateTime        @default(now()) @map("created_at")
  updatedAt        DateTime        @updatedAt @map("updated_at")
  deletedAt        DateTime?       @map("deleted_at")

  roles            AdminUserRole[]
  loginHistory     AdminLoginHistory[]
  auditLogs        AuditLog[]
  blogPosts        BlogPost[]
  customerNotes    CustomerNote[]
  customerCallLogs CustomerCallLog[]

  @@map("admin_users")
}

model AdminLoginHistory {
  id          Int      @id @default(autoincrement())
  adminUserId Int      @map("admin_user_id")
  ipAddress   String?  @map("ip_address")
  userAgent   String?  @map("user_agent")
  success     Boolean
  createdAt   DateTime @default(now()) @map("created_at")

  adminUser AdminUser @relation(fields: [adminUserId], references: [id], onDelete: Cascade)

  @@map("admin_login_history")
}

// Admin-defined, e.g. "Order Manager", "Content Editor" (AGENTS.md §4.2).
model Role {
  id          Int      @id @default(autoincrement())
  name        String   @unique
  description String?
  isSystem    Boolean  @default(false) @map("is_system") // protects e.g. "Super Admin" from deletion
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  permissions RolePermission[]
  adminUsers  AdminUserRole[]

  @@map("roles")
}

// Granular, resource+action based (AGENTS.md §4.2), e.g. "product.create".
// A real table (not a JSON blob like the old app's users.permissions) so
// @RequirePermission + the seeded catalog stay the single source of truth.
model Permission {
  id       Int    @id @default(autoincrement())
  resource String
  action   String
  key      String @unique // "<resource>.<action>", matches @RequirePermission()

  roles RolePermission[]

  @@map("permissions")
}

model RolePermission {
  roleId       Int @map("role_id")
  permissionId Int @map("permission_id")

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@map("role_permissions")
}

model AdminUserRole {
  adminUserId Int @map("admin_user_id")
  roleId      Int @map("role_id")

  adminUser AdminUser @relation(fields: [adminUserId], references: [id], onDelete: Cascade)
  role      Role      @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([adminUserId, roleId])
  @@map("admin_user_roles")
}

// ---------------------------------------------------------------------
// Customer auth + accounts (AGENTS.md §4.1)
// ---------------------------------------------------------------------

enum CustomerStatus {
  ACTIVE
  LOCKED
}

model Customer {
  id                  Int            @id @default(autoincrement())
  // Old system made email nullable + dropped its unique index to support
  // phone-first (OTP) signup — we keep both nullable+unique (Postgres treats
  // NULLs as distinct) instead of forcing one required identifier.
  email               String?        @unique
  phone               String?        @unique
  passwordHash        String?        @map("password_hash") // null for OTP/social-only accounts
  firstName           String?        @map("first_name")
  lastName            String?        @map("last_name")
  avatarUrl           String?        @map("avatar_url")
  dob                 DateTime?      @db.Date
  status              CustomerStatus @default(ACTIVE)
  emailVerifiedAt     DateTime?      @map("email_verified_at")
  phoneVerifiedAt     DateTime?      @map("phone_verified_at")
  legacyId            Int?           @unique @map("legacy_id") // ec_customers.id, for B12 ETL matching
  completedOrderCount Int            @default(0) @map("completed_order_count")
  tierId              Int?           @map("tier_id")
  createdAt           DateTime       @default(now()) @map("created_at")
  updatedAt           DateTime       @updatedAt @map("updated_at")
  deletedAt           DateTime?      @map("deleted_at")

  // PHASE 2 HOOK: reward-point ledger and referral-code program attach here.
  // Loyalty/Referral are not implemented — this is the seam only.

  addresses      CustomerAddress[]
  socialAccounts SocialAccount[]
  carts          Cart[]
  orders         Order[]
  reviews        Review[]
  discountUses   DiscountCustomer[]
  redemptions    DiscountRedemption[]
  wishlistItems  WishlistItem[]
  tier           CustomerTier?        @relation(fields: [tierId], references: [id])
  notes          CustomerNote[]
  callLogs       CustomerCallLog[]
  dues           Due[]

  @@map("customers")
}

// Admin-configurable loyalty tiers (thresholds and labels editable via
// /admin/customer-tiers — not a hardcoded enum, so adding/renaming tiers
// never needs a migration). "Current tier" = the row with the highest
// minCompletedOrders that a customer's completedOrderCount meets or exceeds.
model CustomerTier {
  id                 Int      @id @default(autoincrement())
  label              String
  minCompletedOrders Int      @unique @map("min_completed_orders")
  sortOrder          Int      @default(0) @map("sort_order")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  customers Customer[]

  @@map("customer_tiers")
}

enum CustomerNoteType {
  CUSTOMER_FEEDBACK
  INTERNAL_NOTE
  REMARK
}

// Append-only — no edit/delete in this phase. Covers customer feedback,
// internal sales-team notes, and follow-up remarks in one type-tagged model.
model CustomerNote {
  id            Int              @id @default(autoincrement())
  customerId    Int              @map("customer_id")
  type          CustomerNoteType
  body          String
  authorAdminId Int              @map("author_admin_id")
  createdAt     DateTime         @default(now()) @map("created_at")

  customer Customer  @relation(fields: [customerId], references: [id], onDelete: Cascade)
  author   AdminUser @relation(fields: [authorAdminId], references: [id])

  @@map("customer_notes")
}

enum CallOutcome {
  CONNECTED
  NO_ANSWER
  VOICEMAIL
  WRONG_NUMBER
  DECLINED
}

// Logged manually by the agent after a call. providerCallId stays null
// until a real CallProvider exists (see Task 4).
model CustomerCallLog {
  id             Int         @id @default(autoincrement())
  customerId     Int         @map("customer_id")
  phoneCalled    String      @map("phone_called")
  outcome        CallOutcome
  notes          String?
  authorAdminId  Int         @map("author_admin_id")
  providerCallId String?     @map("provider_call_id")
  createdAt      DateTime    @default(now()) @map("created_at")

  customer Customer  @relation(fields: [customerId], references: [id], onDelete: Cascade)
  author   AdminUser @relation(fields: [authorAdminId], references: [id])

  @@map("customer_call_logs")
}

model CustomerAddress {
  id            Int      @id @default(autoincrement())
  customerId    Int      @map("customer_id")
  label         String? // e.g. "Home", "Office"
  recipientName String   @map("recipient_name")
  phone         String
  division      String // Bangladesh division — kept as plain text (single-country now)
  district      String
  area          String? // thana/upazila
  landmark      String?
  addressLine   String   @map("address_line")
  postCode      String?  @map("post_code")
  isDefault     Boolean  @default(false) @map("is_default")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@map("customer_addresses")
}

enum OtpPurpose {
  REGISTER
  LOGIN
  RESET_PASSWORD
  COD_VERIFICATION
  ADMIN_LOGIN
}

// Identifier-based (phone or email), not FK'd to Customer — OTP happens
// before an account necessarily exists (registration flow).
model Otp {
  id         Int        @id @default(autoincrement())
  identifier String
  purpose    OtpPurpose
  code       String
  ipAddress  String?    @map("ip_address") // ADDENDUM §I
  isVpn      Boolean    @default(false) @map("is_vpn") // ADDENDUM §I — VPN/proxy detected at request time
  attempts   Int        @default(0) // ADDENDUM §I — verify attempts against this row
  expiresAt  DateTime   @map("expires_at")
  consumedAt DateTime?  @map("consumed_at")
  createdAt  DateTime   @default(now()) @map("created_at")

  @@index([identifier, purpose])
  @@map("otps")
}

enum SocialProvider {
  GOOGLE
  FACEBOOK
}

model SocialAccount {
  id             Int            @id @default(autoincrement())
  customerId     Int            @map("customer_id")
  provider       SocialProvider
  providerUserId String         @map("provider_user_id")
  accessToken    String?        @map("access_token")
  refreshToken   String?        @map("refresh_token")
  tokenExpiresAt DateTime?      @map("token_expires_at")
  createdAt      DateTime       @default(now()) @map("created_at")

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@unique([provider, providerUserId])
  @@map("social_accounts")
}

// ---------------------------------------------------------------------
// Catalog: brand / category / tag
// ---------------------------------------------------------------------

enum ContentStatus {
  DRAFT
  PENDING
  PUBLISHED
  ARCHIVED
}

model Brand {
  id         Int           @id @default(autoincrement())
  slug       String        @unique
  legacySlug String?       @map("legacy_slug") // preserves old URL for 301s (AGENTS.md §9)
  logoUrl    String?       @map("logo_url")
  websiteUrl String?       @map("website_url")
  isFeatured Boolean       @default(false) @map("is_featured")
  sortOrder  Int           @default(0) @map("sort_order")
  status     ContentStatus @default(DRAFT)
  legacyId   Int?          @unique @map("legacy_id")
  createdAt  DateTime      @default(now()) @map("created_at")
  updatedAt  DateTime      @updatedAt @map("updated_at")
  deletedAt  DateTime?     @map("deleted_at")

  translations BrandTranslation[]
  products     Product[]

  @@map("brands")
}

model BrandTranslation {
  id          Int     @id @default(autoincrement())
  brandId     Int     @map("brand_id")
  locale      Locale
  name        String
  description String?

  brand Brand @relation(fields: [brandId], references: [id], onDelete: Cascade)

  @@unique([brandId, locale])
  @@map("brand_translations")
}

// Self-referencing tree, same shape as the old app's category models —
// this part of Botble's design was fine, kept as-is.
model Category {
  id         Int           @id @default(autoincrement())
  slug       String        @unique
  legacySlug String?       @map("legacy_slug")
  parentId   Int?          @map("parent_id")
  imageUrl   String?       @map("image_url")
  iconUrl    String?       @map("icon_url")
  isFeatured Boolean       @default(false) @map("is_featured")
  sortOrder  Int           @default(0) @map("sort_order")
  status     ContentStatus @default(DRAFT)
  legacyId   Int?          @unique @map("legacy_id")
  createdAt  DateTime      @default(now()) @map("created_at")
  updatedAt  DateTime      @updatedAt @map("updated_at")
  deletedAt  DateTime?     @map("deleted_at")

  parent   Category?  @relation("CategoryTree", fields: [parentId], references: [id], onDelete: SetNull)
  children Category[] @relation("CategoryTree")

  translations   CategoryTranslation[]
  products       ProductCategory[]
  discountScopes DiscountCategory[]

  @@map("categories")
}

model CategoryTranslation {
  id          Int     @id @default(autoincrement())
  categoryId  Int     @map("category_id")
  locale      Locale
  name        String
  description String?

  category Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@unique([categoryId, locale])
  @@map("category_translations")
}

model Tag {
  id         Int           @id @default(autoincrement())
  slug       String        @unique
  legacySlug String?       @map("legacy_slug")
  status     ContentStatus @default(DRAFT)
  legacyId   Int?          @unique @map("legacy_id")
  createdAt  DateTime      @default(now()) @map("created_at")
  updatedAt  DateTime      @updatedAt @map("updated_at")
  deletedAt  DateTime?     @map("deleted_at")

  translations TagTranslation[]
  products     ProductTag[]

  @@map("tags")
}

model TagTranslation {
  id          Int     @id @default(autoincrement())
  tagId       Int     @map("tag_id")
  locale      Locale
  name        String
  description String?

  tag Tag @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@unique([tagId, locale])
  @@map("tag_translations")
}

// ---------------------------------------------------------------------
// Catalog: attributes (variation axes) — a lean Attribute/Value/Variant
// design, replacing the old app's approach of duplicating a whole extra
// Product row per SKU combination (see B1 review notes).
// ---------------------------------------------------------------------

model Attribute {
  id        Int      @id @default(autoincrement())
  slug      String   @unique
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at")

  translations AttributeTranslation[]
  values       AttributeValue[]
  productAxes  ProductAttribute[]

  @@map("attributes")
}

model AttributeTranslation {
  id          Int    @id @default(autoincrement())
  attributeId Int    @map("attribute_id")
  locale      Locale
  name        String

  attribute Attribute @relation(fields: [attributeId], references: [id], onDelete: Cascade)

  @@unique([attributeId, locale])
  @@map("attribute_translations")
}

model AttributeValue {
  id          Int     @id @default(autoincrement())
  attributeId Int     @map("attribute_id")
  colorHex    String? @map("color_hex")
  imageUrl    String? @map("image_url")
  sortOrder   Int     @default(0) @map("sort_order")

  attribute    Attribute                      @relation(fields: [attributeId], references: [id], onDelete: Cascade)
  translations AttributeValueTranslation[]
  variantLinks ProductVariantAttributeValue[]

  @@map("attribute_values")
}

model AttributeValueTranslation {
  id               Int    @id @default(autoincrement())
  attributeValueId Int    @map("attribute_value_id")
  locale           Locale
  value            String

  attributeValue AttributeValue @relation(fields: [attributeValueId], references: [id], onDelete: Cascade)

  @@unique([attributeValueId, locale])
  @@map("attribute_value_translations")
}

// ---------------------------------------------------------------------
// Catalog: product
// ---------------------------------------------------------------------

enum ProductType {
  PHYSICAL
  DIGITAL
}

enum StockStatus {
  IN_STOCK
  OUT_OF_STOCK
  ON_BACKORDER
}

model Product {
  id         Int     @id @default(autoincrement())
  slug       String  @unique
  legacySlug String? @map("legacy_slug")
  sku        String? @unique
  brandId    Int?    @map("brand_id")

  productType ProductType   @default(PHYSICAL) @map("product_type")
  status      ContentStatus @default(DRAFT)
  isFeatured  Boolean       @default(false) @map("is_featured")
  sortOrder   Int           @default(0) @map("sort_order")
  viewCount   Int           @default(0) @map("view_count")
  videoUrl    String?       @map("video_url") // embedded video reference (product detail gallery)

  // Simple (non-variant) products price/stock live directly here. Variant
  // products (hasVariants=true) keep price/stock on ProductVariant instead.
  hasVariants    Boolean     @default(false) @map("has_variants")
  trackInventory Boolean     @default(true) @map("track_inventory")
  allowBackorder Boolean     @default(false) @map("allow_backorder")
  stock          Int         @default(0)
  // Held during checkout so concurrent buyers can't oversell (old app had
  // no reservation at all — a real gap we're deliberately closing, see
  // AGENTS.md §6 "reserved-stock accounting during checkout"). Populated by B6.
  reservedStock  Int         @default(0) @map("reserved_stock")
  stockStatus    StockStatus @default(IN_STOCK) @map("stock_status")
  price          Decimal?    @db.Decimal(10, 2)
  salePrice      Decimal?    @map("sale_price") @db.Decimal(10, 2)
  saleStartsAt   DateTime?   @map("sale_starts_at")
  saleEndsAt     DateTime?   @map("sale_ends_at")
  costPerItem    Decimal?    @map("cost_per_item") @db.Decimal(10, 2)

  // Accurate shippable weight for courier charging (AGENTS.md §5/§11),
  // editable — not just a label/box-volume figure. Kilograms.
  shippableWeight Decimal? @map("shippable_weight") @db.Decimal(10, 3)

  minOrderQuantity Int  @default(1) @map("min_order_quantity")
  maxOrderQuantity Int? @map("max_order_quantity")

  // PDP "Product Info Visual" section — center image + 3 circular ingredient
  // images. Not translatable (same images regardless of locale), unlike the
  // headings/captions around them (see ProductTranslation.infoVisualContent).
  // Shape: { main: string, circles: [string, string, string] }.
  infoVisualImages Json? @map("info_visual_images")

  // PDP "Comparison" section — one image per card, not translatable (see
  // ProductTranslation.comparisonContent for the translatable heading/
  // titles/list text). Shape: { card1: string, card2: string }.
  comparisonImages Json? @map("comparison_images")

  legacyId  Int?      @unique @map("legacy_id")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  // PHASE 2 HOOK: batch/expiry tracking, warehouse bins, per-warehouse
  // stock, and costing method attach here. Do not build now.

  brand          Brand?               @relation(fields: [brandId], references: [id], onDelete: SetNull)
  translations   ProductTranslation[]
  categories     ProductCategory[]
  tags           ProductTag[]
  attributes     ProductAttribute[]
  variants       ProductVariant[]
  media          ProductMedia[]
  files          ProductFile[]
  licenseCodes   ProductLicenseCode[]
  bundleItems    ProductBundleItem[]
  relationsFrom  ProductRelation[]    @relation("ProductRelationFrom")
  relationsTo    ProductRelation[]    @relation("ProductRelationTo")
  cartItems      CartItem[]
  orderItems     OrderItem[]
  reviews        Review[]
  discountScopes DiscountProduct[]
  wishlistItems  WishlistItem[]
  collections    CollectionProduct[]

  @@index([status])
  @@map("products")
}

model ProductTranslation {
  id          Int     @id @default(autoincrement())
  productId   Int     @map("product_id")
  locale      Locale
  name        String
  description String?
  content     String? // long-form detail/story content
  nutrition   String? // grocery/food product nutrition facts
  ingredients String?
  keyBenefits String? @map("key_benefits") // short benefit lines, one per line — rendered as the PDP's "Key Benefits" grid

  // PDP "Product Info Visual" section text — headings/captions accept raw
  // HTML (admin-authored, same trust level as content/description/etc, no
  // rich-text editor). Shape: { topHeading: string, bottomHeading: string,
  // arrows: [{heading, subheading}, ...4], circleLabels: [string,string,string] }.
  // Paired image URLs (not translatable) live on Product.infoVisualImages.
  infoVisualContent Json? @map("info_visual_content")

  // PDP "Comparison" section text — heading + two cards (card1 = us, styled
  // with checkmarks; card2 = them, styled with X marks — fixed by position,
  // not admin-configurable). Shape: { heading: string, card1: { title:
  // string, items: string }, card2: { title: string, items: string } }.
  // `items` is one bullet line per line of text, same convention as
  // keyBenefits. Paired image URLs (not translatable) live on
  // Product.comparisonImages.
  comparisonContent Json? @map("comparison_content")

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, locale])
  // Trigram GIN index backs typo-tolerant search (pg_trgm similarity/ILIKE),
  // added via a manual migration (CREATE EXTENSION pg_trgm) — see B4.
  @@index([name(ops: raw("gin_trgm_ops"))], type: Gin)
  @@map("product_translations")
}

model ProductCategory {
  productId  Int @map("product_id")
  categoryId Int @map("category_id")

  product  Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  category Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@id([productId, categoryId])
  @@map("product_categories")
}

model ProductTag {
  productId Int @map("product_id")
  tagId     Int @map("tag_id")

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  tag     Tag     @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([productId, tagId])
  @@map("product_tags")
}

// Which variation axes (e.g. Color, Size) this product uses.
model ProductAttribute {
  productId   Int @map("product_id")
  attributeId Int @map("attribute_id")
  sortOrder   Int @default(0) @map("sort_order")

  product   Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  attribute Attribute @relation(fields: [attributeId], references: [id], onDelete: Cascade)

  @@id([productId, attributeId])
  @@map("product_attributes")
}

// A real, lean variant row (own SKU/price/stock) — NOT a duplicate Product
// row like the old app. See B1 review notes for why.
model ProductVariant {
  id             Int         @id @default(autoincrement())
  productId      Int         @map("product_id")
  sku            String?     @unique
  barcode        String?
  price          Decimal     @db.Decimal(10, 2)
  salePrice      Decimal?    @map("sale_price") @db.Decimal(10, 2)
  costPerItem    Decimal?    @map("cost_per_item") @db.Decimal(10, 2) // per-variation buy price (Profit parity) — falls back to Product.costPerItem when unset
  stock          Int         @default(0)
  reservedStock  Int         @default(0) @map("reserved_stock")
  stockStatus    StockStatus @default(IN_STOCK) @map("stock_status")
  weightOverride Decimal?    @map("weight_override") @db.Decimal(10, 3)
  isDefault      Boolean     @default(false) @map("is_default")
  sortOrder      Int         @default(0) @map("sort_order")
  createdAt      DateTime    @default(now()) @map("created_at")
  updatedAt      DateTime    @updatedAt @map("updated_at")

  product         Product                        @relation(fields: [productId], references: [id], onDelete: Cascade)
  attributeValues ProductVariantAttributeValue[]
  cartItems       CartItem[]
  orderItems      OrderItem[]
  licenseCodes    ProductLicenseCode[]
  bundleItems     ProductBundleItem[]

  @@map("product_variants")
}

// Per-SKU attribute selection, e.g. this variant = {Color: Red, Size: M}.
model ProductVariantAttributeValue {
  variantId        Int @map("variant_id")
  attributeValueId Int @map("attribute_value_id")

  variant        ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)
  attributeValue AttributeValue @relation(fields: [attributeValueId], references: [id], onDelete: Cascade)

  @@id([variantId, attributeValueId])
  @@map("product_variant_attribute_values")
}

model ProductMedia {
  productId Int     @map("product_id")
  mediaId   Int     @map("media_id")
  sortOrder Int     @default(0) @map("sort_order")
  isPrimary Boolean @default(false) @map("is_primary")

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  media   Media   @relation(fields: [mediaId], references: [id], onDelete: Cascade)

  @@id([productId, mediaId])
  @@map("product_media")
}

// Digital-product downloadable attachments.
model ProductFile {
  id        Int      @id @default(autoincrement())
  productId Int      @map("product_id")
  url       String
  name      String
  sizeBytes Int?     @map("size_bytes")
  mimeType  String?  @map("mime_type")
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at")

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@map("product_files")
}

enum LicenseCodeStatus {
  AVAILABLE
  USED
}

model ProductLicenseCode {
  id          Int               @id @default(autoincrement())
  productId   Int               @map("product_id")
  variantId   Int?              @map("variant_id")
  code        String            @unique
  status      LicenseCodeStatus @default(AVAILABLE)
  orderItemId Int?              @unique @map("order_item_id")
  assignedAt  DateTime?         @map("assigned_at")
  createdAt   DateTime          @default(now()) @map("created_at")

  product   Product         @relation(fields: [productId], references: [id], onDelete: Cascade)
  variant   ProductVariant? @relation(fields: [variantId], references: [id], onDelete: SetNull)
  orderItem OrderItem?      @relation(fields: [orderItemId], references: [id], onDelete: SetNull)

  @@map("product_license_codes")
}

// A named, fixed combo pack ("Buy together, save 10%"), distinct from the
// quantity-threshold Discount engine below.
model ProductBundle {
  id          Int           @id @default(autoincrement())
  slug        String        @unique
  bundlePrice Decimal?      @map("bundle_price") @db.Decimal(10, 2)
  discountPct Decimal?      @map("discount_pct") @db.Decimal(5, 2)
  status      ContentStatus @default(DRAFT)
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")

  translations ProductBundleTranslation[]
  items        ProductBundleItem[]

  @@map("product_bundles")
}

model ProductBundleTranslation {
  id          Int     @id @default(autoincrement())
  bundleId    Int     @map("bundle_id")
  locale      Locale
  name        String
  description String?

  bundle ProductBundle @relation(fields: [bundleId], references: [id], onDelete: Cascade)

  @@unique([bundleId, locale])
  @@map("product_bundle_translations")
}

model ProductBundleItem {
  id        Int  @id @default(autoincrement())
  bundleId  Int  @map("bundle_id")
  productId Int  @map("product_id")
  variantId Int? @map("variant_id")
  quantity  Int  @default(1)

  bundle  ProductBundle   @relation(fields: [bundleId], references: [id], onDelete: Cascade)
  product Product         @relation(fields: [productId], references: [id], onDelete: Cascade)
  variant ProductVariant? @relation(fields: [variantId], references: [id], onDelete: SetNull)

  @@map("product_bundle_items")
}

enum ProductRelationType {
  RELATED
  CROSS_SELL
  UP_SELL
  FREQUENTLY_BOUGHT_TOGETHER
}

// One flexible table instead of the old app's three separate pivot tables.
model ProductRelation {
  fromProductId Int                 @map("from_product_id")
  toProductId   Int                 @map("to_product_id")
  type          ProductRelationType

  fromProduct Product @relation("ProductRelationFrom", fields: [fromProductId], references: [id], onDelete: Cascade)
  toProduct   Product @relation("ProductRelationTo", fields: [toProductId], references: [id], onDelete: Cascade)

  @@id([fromProductId, toProductId, type])
  @@map("product_relations")
}

// ---------------------------------------------------------------------
// Cart
// ---------------------------------------------------------------------

// DB-backed so a logged-in customer's cart survives across devices; Redis
// caching in front of this is a later optimization, not a schema concern.
model Cart {
  id         Int       @id @default(autoincrement())
  customerId Int?      @map("customer_id") // null for guest carts
  guestToken String?   @unique @map("guest_token")
  couponCode String?   @map("coupon_code")
  currency   String    @default("BDT")
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")
  expiresAt  DateTime? @map("expires_at")

  customer Customer?  @relation(fields: [customerId], references: [id], onDelete: Cascade)
  items    CartItem[]

  @@map("carts")
}

model CartItem {
  id                Int      @id @default(autoincrement())
  cartId            Int      @map("cart_id")
  productId         Int      @map("product_id")
  variantId         Int?     @map("variant_id")
  quantity          Int
  unitPriceSnapshot Decimal  @map("unit_price_snapshot") @db.Decimal(10, 2)
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  cart    Cart            @relation(fields: [cartId], references: [id], onDelete: Cascade)
  product Product         @relation(fields: [productId], references: [id], onDelete: Cascade)
  variant ProductVariant? @relation(fields: [variantId], references: [id], onDelete: Cascade)

  @@unique([cartId, productId, variantId])
  @@map("cart_items")
}

model WishlistItem {
  id         Int      @id @default(autoincrement())
  customerId Int      @map("customer_id")
  productId  Int      @map("product_id")
  createdAt  DateTime @default(now()) @map("created_at")

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  product  Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([customerId, productId])
  @@map("wishlist_items")
}

// ---------------------------------------------------------------------
// Orders
// ---------------------------------------------------------------------

enum OrderStatus {
  PENDING
  CONFIRMED // Net Profit Order Manager (§7.8): staff has reviewed/confirmed before packing
  PROCESSING
  COMPLETED
  CANCELED
  PARTIALLY_RETURNED
  RETURNED
  HOLD // Net Profit fraud/advance-payment hold — courier-stage detail (packed/consigned/
  // in_transit/delivered) already lives on Shipment.status; not duplicated here.
}

enum OrderChannel {
  WEBSITE
  WHATSAPP
  PHONE
  MARKETPLACE
  POS
  APP
}

model Order {
  id          Int          @id @default(autoincrement())
  orderNumber String       @unique @map("order_number")
  customerId  Int?         @map("customer_id") // null = guest order
  status      OrderStatus  @default(PENDING)
  channel     OrderChannel @default(WEBSITE) @map("channel")

  subTotal       Decimal @map("sub_total") @db.Decimal(10, 2)
  discountAmount Decimal @default(0) @map("discount_amount") @db.Decimal(10, 2)
  taxAmount      Decimal @default(0) @map("tax_amount") @db.Decimal(10, 2)
  shippingAmount Decimal @default(0) @map("shipping_amount") @db.Decimal(10, 2)
  totalAmount    Decimal @map("total_amount") @db.Decimal(10, 2)
  currency       String  @default("BDT")
  couponCode     String? @map("coupon_code")

  shippingMethod String? @map("shipping_method")
  customerNote   String? @map("customer_note")
  staffNote      String? @map("staff_note")
  cancelReason   String? @map("cancel_reason")

  // Captured at checkout time — Blocker Manager's ip_tracker/device rules
  // need a durable per-order IP/device, not just the live request (mirrors
  // Otp.ipAddress, ADDENDUM §I's existing pattern for the same reason).
  ipAddress String? @map("ip_address")
  deviceId  String? @map("device_id")

  // Campaign attribution — captured client-side from the landing URL's
  // utm_* params (apps/web's utm.ts, 30-day cookie) and passed through at
  // checkout, same "captured at checkout time" pattern as ipAddress/deviceId
  // above. Nullable: most orders (direct traffic, no ad click) have none.
  utmSource   String? @map("utm_source")
  utmMedium   String? @map("utm_medium")
  utmCampaign String? @map("utm_campaign")
  utmTerm     String? @map("utm_term")
  utmContent  String? @map("utm_content")

  // Durable proof of COD phone-OTP verification (mirrors Review.orderItemId —
  // a stored fact, not just trusting an Otp row got consumed at some point).
  codVerifiedAt DateTime? @map("cod_verified_at")

  legacyId    Int?      @unique @map("legacy_id")
  confirmedAt DateTime? @map("confirmed_at")
  completedAt DateTime? @map("completed_at")
  canceledAt  DateTime? @map("canceled_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  customer       Customer?               @relation(fields: [customerId], references: [id], onDelete: SetNull)
  items          OrderItem[]
  addresses      OrderAddress[]
  statusHistory  OrderStatusHistory[]
  reviews        Review[]
  discountUses   DiscountRedemption[]
  voucherUses    GiftVoucherRedemption[]
  payments       Payment[]
  shipments      Shipment[]
  fraudSavings   FraudSaving[]
  advancePayment AdvancePayment?
  manualPayments ManualPayment[]
  profit         OrderProfit?

  @@index([status])
  @@map("orders")
}

// Snapshots product name/price/sku at time of purchase — deliberately kept
// from the old app's design, this part was correct (order history must not
// change retroactively if the product is later edited/deleted).
model OrderItem {
  id                  Int       @id @default(autoincrement())
  orderId             Int       @map("order_id")
  productId           Int?      @map("product_id")
  variantId           Int?      @map("variant_id")
  productNameSnapshot String    @map("product_name_snapshot")
  skuSnapshot         String?   @map("sku_snapshot")
  unitPrice           Decimal   @map("unit_price") @db.Decimal(10, 2)
  quantity            Int
  taxAmount           Decimal   @default(0) @map("tax_amount") @db.Decimal(10, 2)
  optionsSnapshot     Json?     @map("options_snapshot")
  restockedQuantity   Int       @default(0) @map("restocked_quantity")
  downloadedAt        DateTime? @map("downloaded_at") // digital products

  order       Order               @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product     Product?            @relation(fields: [productId], references: [id], onDelete: SetNull)
  variant     ProductVariant?     @relation(fields: [variantId], references: [id], onDelete: SetNull)
  licenseCode ProductLicenseCode?

  @@map("order_items")
}

enum OrderAddressType {
  SHIPPING
  BILLING
}

model OrderAddress {
  id            Int              @id @default(autoincrement())
  orderId       Int              @map("order_id")
  type          OrderAddressType
  recipientName String           @map("recipient_name")
  phone         String
  email         String?
  division      String
  district      String
  area          String? // thana/upazila
  landmark      String?
  addressLine   String           @map("address_line")
  postCode      String?          @map("post_code")

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@unique([orderId, type])
  @@map("order_addresses")
}

model OrderStatusHistory {
  id          Int         @id @default(autoincrement())
  orderId     Int         @map("order_id")
  status      OrderStatus
  note        String?
  adminUserId Int?        @map("admin_user_id") // null = system/customer-triggered
  createdAt   DateTime    @default(now()) @map("created_at")

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@map("order_status_history")
}

// ---------------------------------------------------------------------
// Payments (B6) — abstraction now, gateways activated when credentials
// arrive (AGENTS.md §6). COD works end-to-end today; bKash/Nagad/SSLCommerz/
// Bank Transfer sit behind the same PaymentProvider interface as stubs.
// ---------------------------------------------------------------------

enum PaymentProvider {
  COD
  BKASH
  NAGAD
  ROCKET // added for Net Profit Manual Payment (§7.12, M4) — bKash/Nagad already existed, Rocket didn't
  UPAY // ADDENDUM §J
  SSLCOMMERZ
  BANK_TRANSFER
}

enum PaymentStatus {
  PENDING
  AUTHORIZED
  CAPTURED
  FAILED
  REFUNDED
  PARTIALLY_REFUNDED
}

model Payment {
  id             Int             @id @default(autoincrement())
  orderId        Int             @map("order_id")
  provider       PaymentProvider
  status         PaymentStatus   @default(PENDING)
  amount         Decimal         @db.Decimal(10, 2)
  currency       String          @default("BDT")
  transactionRef String?         @map("transaction_ref")
  refundedAmount Decimal?        @map("refunded_amount") @db.Decimal(10, 2)
  rawResponse    Json?           @map("raw_response")
  createdAt      DateTime        @default(now()) @map("created_at")
  updatedAt      DateTime        @updatedAt @map("updated_at")

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@map("payments")
}

// ---------------------------------------------------------------------
// Courier & Fulfilment (B7) — abstraction now, providers as credentials
// arrive (AGENTS.md §6). Steadfast has a real implementation (proven in the
// reference codebase); Pathao/RedX/eCourier are stubs behind the same
// interface. requestPayload + rawResponse are stored on every attempt,
// success or failure — the old app only ever stored the response, and only
// on failure — so there's always a durable cross-reference copy of exactly
// what we sent/received.
// ---------------------------------------------------------------------

enum CourierProviderName {
  STEADFAST
  PATHAO
  REDX
  ECOURIER
}

enum ShipmentStatus {
  PENDING
  DISPATCHED
  IN_TRANSIT
  DELIVERED
  PARTIALLY_DELIVERED
  RETURNED
  CANCELED
  FAILED
}

model Shipment {
  id             Int                 @id @default(autoincrement())
  orderId        Int                 @map("order_id")
  provider       CourierProviderName
  status         ShipmentStatus      @default(PENDING)
  consignmentId  String?             @map("consignment_id")
  trackingCode   String?             @map("tracking_code")
  cost           Decimal?            @db.Decimal(10, 2)
  weight         Decimal?            @db.Decimal(10, 3)
  codAmount      Decimal?            @map("cod_amount") @db.Decimal(10, 2)
  returnReason   String?             @map("return_reason")
  errorMessage   String?             @map("error_message")
  requestPayload Json?               @map("request_payload")
  rawResponse    Json?               @map("raw_response")
  dispatchedAt   DateTime?           @map("dispatched_at")
  deliveredAt    DateTime?           @map("delivered_at")
  createdAt      DateTime            @default(now()) @map("created_at")
  updatedAt      DateTime            @updatedAt @map("updated_at")

  order  Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)
  events ShipmentEvent[]

  @@map("shipments")
}

model ShipmentEvent {
  id         Int            @id @default(autoincrement())
  shipmentId Int            @map("shipment_id")
  status     ShipmentStatus
  note       String?
  rawPayload Json?          @map("raw_payload")
  occurredAt DateTime       @default(now()) @map("occurred_at")

  shipment Shipment @relation(fields: [shipmentId], references: [id], onDelete: Cascade)

  @@map("shipment_events")
}

// ---------------------------------------------------------------------
// Promotions: coupons/promotions + gift vouchers (two different things —
// a voucher is prepaid stored value, not a percent/fixed-amount discount)
// ---------------------------------------------------------------------

enum DiscountType {
  COUPON
  PROMOTION
}

enum DiscountValueType {
  PERCENTAGE
  FIXED_AMOUNT
  FREE_SHIPPING
}

model Discount {
  id                 Int               @id @default(autoincrement())
  code               String?           @unique // null for auto-applied PROMOTION
  type               DiscountType
  valueType          DiscountValueType @map("value_type")
  value              Decimal           @db.Decimal(10, 2)
  minOrderAmount     Decimal?          @map("min_order_amount") @db.Decimal(10, 2)
  maxUsesTotal       Int?              @map("max_uses_total")
  maxUsesPerCustomer Int?              @map("max_uses_per_customer")
  usedCount          Int               @default(0) @map("used_count")
  startsAt           DateTime?         @map("starts_at")
  endsAt             DateTime?         @map("ends_at")
  status             ContentStatus     @default(DRAFT)
  legacyId           Int?              @unique @map("legacy_id")
  createdAt          DateTime          @default(now()) @map("created_at")
  updatedAt          DateTime          @updatedAt @map("updated_at")

  products    DiscountProduct[]
  categories  DiscountCategory[]
  customers   DiscountCustomer[]
  redemptions DiscountRedemption[]

  @@map("discounts")
}

model DiscountProduct {
  discountId Int @map("discount_id")
  productId  Int @map("product_id")

  discount Discount @relation(fields: [discountId], references: [id], onDelete: Cascade)
  product  Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@id([discountId, productId])
  @@map("discount_products")
}

model DiscountCategory {
  discountId Int @map("discount_id")
  categoryId Int @map("category_id")

  discount Discount @relation(fields: [discountId], references: [id], onDelete: Cascade)
  category Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@id([discountId, categoryId])
  @@map("discount_categories")
}

// Eligibility restriction (which customers may use this discount at all).
model DiscountCustomer {
  discountId Int @map("discount_id")
  customerId Int @map("customer_id")

  discount Discount @relation(fields: [discountId], references: [id], onDelete: Cascade)
  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@id([discountId, customerId])
  @@map("discount_customers")
}

// Actual usage history, tied to the order it was redeemed on (the old app's
// equivalent tracked customer+coupon only, not which order — worse for audit).
model DiscountRedemption {
  id         Int      @id @default(autoincrement())
  discountId Int      @map("discount_id")
  customerId Int?     @map("customer_id")
  orderId    Int      @map("order_id")
  redeemedAt DateTime @default(now()) @map("redeemed_at")

  discount Discount  @relation(fields: [discountId], references: [id], onDelete: Cascade)
  customer Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)
  order    Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@map("discount_redemptions")
}

enum GiftVoucherStatus {
  ACTIVE
  REDEEMED
  EXPIRED
}

model GiftVoucher {
  id                    Int               @id @default(autoincrement())
  code                  String            @unique
  initialBalance        Decimal           @map("initial_balance") @db.Decimal(10, 2)
  remainingBalance      Decimal           @map("remaining_balance") @db.Decimal(10, 2)
  currency              String            @default("BDT")
  status                GiftVoucherStatus @default(ACTIVE)
  expiresAt             DateTime?         @map("expires_at")
  purchasedByCustomerId Int?              @map("purchased_by_customer_id")
  createdAt             DateTime          @default(now()) @map("created_at")

  redemptions GiftVoucherRedemption[]

  @@map("gift_vouchers")
}

model GiftVoucherRedemption {
  id         Int      @id @default(autoincrement())
  voucherId  Int      @map("voucher_id")
  orderId    Int      @map("order_id")
  amountUsed Decimal  @map("amount_used") @db.Decimal(10, 2)
  redeemedAt DateTime @default(now()) @map("redeemed_at")

  voucher GiftVoucher @relation(fields: [voucherId], references: [id], onDelete: Cascade)
  order   Order       @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@map("gift_voucher_redemptions")
}

// ---------------------------------------------------------------------
// Reviews — verified-purchase enforced by a real FK (orderItemId is
// required), not just an app-layer check like the old system.
// ---------------------------------------------------------------------

enum ReviewStatus {
  PENDING
  APPROVED
  REJECTED
}

model Review {
  id          Int          @id @default(autoincrement())
  productId   Int          @map("product_id")
  customerId  Int          @map("customer_id")
  orderItemId Int          @unique @map("order_item_id") // proves verified purchase
  rating      Int
  comment     String?
  images      String[]     @default([])
  status      ReviewStatus @default(PENDING)
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")

  product  Product      @relation(fields: [productId], references: [id], onDelete: Cascade)
  customer Customer     @relation(fields: [customerId], references: [id], onDelete: Cascade)
  reply    ReviewReply?
  order    Order?       @relation(fields: [orderId], references: [id])
  orderId  Int?

  @@unique([productId, customerId])
  @@map("reviews")
}

model ReviewReply {
  id          Int      @id @default(autoincrement())
  reviewId    Int      @unique @map("review_id")
  adminUserId Int      @map("admin_user_id")
  message     String
  createdAt   DateTime @default(now()) @map("created_at")

  review Review @relation(fields: [reviewId], references: [id], onDelete: Cascade)

  @@map("review_replies")
}

// ---------------------------------------------------------------------
// Blog
// ---------------------------------------------------------------------

model BlogPost {
  id          Int           @id @default(autoincrement())
  slug        String        @unique
  legacySlug  String?       @map("legacy_slug")
  adminUserId Int           @map("admin_user_id") // author; a Role like "Content Editor" governs who may post
  status      ContentStatus @default(DRAFT)
  isFeatured  Boolean       @default(false) @map("is_featured")
  imageUrl    String?       @map("image_url")
  publishedAt DateTime?     @map("published_at")
  viewCount   Int           @default(0) @map("view_count")
  legacyId    Int?          @unique @map("legacy_id")
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")
  deletedAt   DateTime?     @map("deleted_at")

  author       AdminUser             @relation(fields: [adminUserId], references: [id], onDelete: Restrict)
  translations BlogPostTranslation[]
  categories   BlogPostCategory[]
  tags         BlogPostTag[]

  @@map("blog_posts")
}

model BlogPostTranslation {
  id              Int     @id @default(autoincrement())
  postId          Int     @map("post_id")
  locale          Locale
  title           String
  excerpt         String?
  content         String
  metaDescription String? @map("meta_description")
  // Cached score for the per-article SEO-score feature (AGENTS.md §6);
  // recomputed by the content-editing flow, not derived at read time.
  seoScore        Int?    @map("seo_score")

  post BlogPost      @relation(fields: [postId], references: [id], onDelete: Cascade)
  faqs BlogPostFaq[]

  @@unique([postId, locale])
  @@map("blog_post_translations")
}

// Per-article FAQ (AGENTS.md §6) — hangs off the translation, not the post,
// since Q&A text is locale-specific; backs the FAQPage structured data in B10.
model BlogPostFaq {
  id            Int    @id @default(autoincrement())
  translationId Int    @map("translation_id")
  question      String
  answer        String
  sortOrder     Int    @default(0) @map("sort_order")

  translation BlogPostTranslation @relation(fields: [translationId], references: [id], onDelete: Cascade)

  @@map("blog_post_faqs")
}

model BlogCategory {
  id         Int           @id @default(autoincrement())
  slug       String        @unique
  legacySlug String?       @map("legacy_slug")
  parentId   Int?          @map("parent_id")
  sortOrder  Int           @default(0) @map("sort_order")
  status     ContentStatus @default(DRAFT)
  legacyId   Int?          @unique @map("legacy_id")
  createdAt  DateTime      @default(now()) @map("created_at")
  updatedAt  DateTime      @updatedAt @map("updated_at")

  parent   BlogCategory?  @relation("BlogCategoryTree", fields: [parentId], references: [id], onDelete: SetNull)
  children BlogCategory[] @relation("BlogCategoryTree")

  translations BlogCategoryTranslation[]
  posts        BlogPostCategory[]

  @@map("blog_categories")
}

model BlogCategoryTranslation {
  id          Int     @id @default(autoincrement())
  categoryId  Int     @map("category_id")
  locale      Locale
  name        String
  description String?

  category BlogCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@unique([categoryId, locale])
  @@map("blog_category_translations")
}

model BlogTag {
  id         Int           @id @default(autoincrement())
  slug       String        @unique
  legacySlug String?       @map("legacy_slug")
  status     ContentStatus @default(DRAFT)
  legacyId   Int?          @unique @map("legacy_id")
  createdAt  DateTime      @default(now()) @map("created_at")

  translations BlogTagTranslation[]
  posts        BlogPostTag[]

  @@map("blog_tags")
}

model BlogTagTranslation {
  id     Int    @id @default(autoincrement())
  tagId  Int    @map("tag_id")
  locale Locale
  name   String

  tag BlogTag @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@unique([tagId, locale])
  @@map("blog_tag_translations")
}

model BlogPostCategory {
  postId     Int @map("post_id")
  categoryId Int @map("category_id")

  post     BlogPost     @relation(fields: [postId], references: [id], onDelete: Cascade)
  category BlogCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@id([postId, categoryId])
  @@map("blog_post_categories")
}

model BlogPostTag {
  postId Int @map("post_id")
  tagId  Int @map("tag_id")

  post BlogPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  tag  BlogTag  @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([postId, tagId])
  @@map("blog_post_tags")
}

// ---------------------------------------------------------------------
// Static pages (AGENTS.md §5 lists "page" alongside product/category/etc.
// as a sluggable, SEO-bearing entity)
// ---------------------------------------------------------------------

model Page {
  id         Int           @id @default(autoincrement())
  slug       String        @unique
  legacySlug String?       @map("legacy_slug")
  status     ContentStatus @default(DRAFT)
  legacyId   Int?          @unique @map("legacy_id")
  createdAt  DateTime      @default(now()) @map("created_at")
  updatedAt  DateTime      @updatedAt @map("updated_at")
  deletedAt  DateTime?     @map("deleted_at")

  translations PageTranslation[]

  @@map("pages")
}

model PageTranslation {
  id      Int    @id @default(autoincrement())
  pageId  Int    @map("page_id")
  locale  Locale
  title   String
  content String

  page Page @relation(fields: [pageId], references: [id], onDelete: Cascade)

  @@unique([pageId, locale])
  @@map("page_translations")
}

// ---------------------------------------------------------------------
// Newsletter — open signup, not gated behind a customer account.
// ---------------------------------------------------------------------

enum NewsletterStatus {
  SUBSCRIBED
  UNSUBSCRIBED
}

model NewsletterSubscriber {
  id             Int              @id @default(autoincrement())
  email          String           @unique
  status         NewsletterStatus @default(SUBSCRIBED)
  subscribedAt   DateTime         @default(now()) @map("subscribed_at")
  unsubscribedAt DateTime?        @map("unsubscribed_at")

  @@map("newsletter_subscribers")
}

// ---------------------------------------------------------------------
// Search (B4) — admin-managed synonym groups so "ছাতু"/"Chatu"/"Sattu" all
// expand to the same search, across EN/BN, without a code change per term.
// ---------------------------------------------------------------------

model SynonymGroup {
  id        Int      @id @default(autoincrement())
  createdAt DateTime @default(now()) @map("created_at")

  terms SynonymTerm[]

  @@map("synonym_groups")
}

model SynonymTerm {
  id      Int    @id @default(autoincrement())
  groupId Int    @map("group_id")
  term    String
  locale  Locale

  group SynonymGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@unique([term, locale])
  @@index([groupId])
  @@map("synonym_terms")
}

// ---------------------------------------------------------------------
// Site content / theme system (B13) — admin-editable homepage composition,
// so section content (hero image/video, which products/posts feature) is
// data, not a frontend code change. New section TYPES still need frontend
// code to render them; instances of existing types are admin-managed.
// ---------------------------------------------------------------------

enum HomepageSectionType {
  HERO_BANNER
  PRODUCT_COLLECTION
  BANNER_STRIP
  CATEGORY_SHOWCASE
  BLOG_TEASER
  CERTIFICATION_ROW
  TESTIMONIAL_BENTO
  CIRCLE_BADGE_BAR
  PROMO_VIDEO
  TABBED_COLLECTION_CAROUSEL
  AD_BANNER
}

model HomepageSection {
  id        Int                 @id @default(autoincrement())
  type      HomepageSectionType
  sortOrder Int                 @default(0) @map("sort_order")
  isActive  Boolean             @default(true) @map("is_active")
  // Shape depends on `type` (e.g. HERO_BANNER: { slides: [{ mediaId, linkUrl? }] }) —
  // validated in the service per-type, not by the DB. See homepage-sections.service.ts.
  config    Json

  // Only meaningful when type = PRODUCT_COLLECTION. A real FK (not JSON) so a
  // deleted collection can't silently orphan a section.
  collectionId Int? @map("collection_id")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  collection   Collection?                  @relation(fields: [collectionId], references: [id], onDelete: SetNull)
  translations HomepageSectionTranslation[]

  @@map("homepage_sections")
}

// Only the heading/subheading are translatable; everything else (media,
// links, which collection) is locale-independent.
model HomepageSectionTranslation {
  id         Int     @id @default(autoincrement())
  sectionId  Int     @map("section_id")
  locale     Locale
  heading    String?
  subheading String? @map("sub_heading")

  section HomepageSection @relation(fields: [sectionId], references: [id], onDelete: Cascade)

  @@unique([sectionId, locale])
  @@map("homepage_section_translations")
}

// Admin-curated product groupings for merchandising display (e.g. "Diwali
// Specials" on the homepage) — distinct from ProductBundle, which is a
// pricing/discount mechanic, not a display grouping.
model Collection {
  id        Int           @id @default(autoincrement())
  slug      String        @unique
  status    ContentStatus @default(DRAFT)
  sortOrder Int           @default(0) @map("sort_order")
  // Distinct from `status`: a collection can be PUBLISHED (viewable via its
  // own page / a homepage section) without cluttering the top navbar, or vice
  // versa. Admin-controlled opt-in per collection.
  showInNav Boolean       @default(false) @map("show_in_nav")
  createdAt DateTime      @default(now()) @map("created_at")
  updatedAt DateTime      @updatedAt @map("updated_at")
  deletedAt DateTime?     @map("deleted_at")

  translations     CollectionTranslation[]
  products         CollectionProduct[]
  homepageSections HomepageSection[]

  @@map("collections")
}

model CollectionTranslation {
  id           Int     @id @default(autoincrement())
  collectionId Int     @map("collection_id")
  locale       Locale
  name         String
  description  String?

  collection Collection @relation(fields: [collectionId], references: [id], onDelete: Cascade)

  @@unique([collectionId, locale])
  @@map("collection_translations")
}

model CollectionProduct {
  id           Int @id @default(autoincrement())
  collectionId Int @map("collection_id")
  productId    Int @map("product_id")
  sortOrder    Int @default(0) @map("sort_order")

  collection Collection @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  product    Product    @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([collectionId, productId])
  @@map("collection_products")
}

// Admin-managed nav menu (AGENTS.web.md §11 open item: "Nav/menu source" —
// resolved here instead of a frontend-only static config).
model MenuItem {
  id        Int      @id @default(autoincrement())
  parentId  Int?     @map("parent_id")
  href      String
  sortOrder Int      @default(0) @map("sort_order")
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  parent   MenuItem?  @relation("MenuItemTree", fields: [parentId], references: [id], onDelete: Cascade)
  children MenuItem[] @relation("MenuItemTree")

  translations MenuItemTranslation[]

  @@map("menu_items")
}

model MenuItemTranslation {
  id         Int    @id @default(autoincrement())
  menuItemId Int    @map("menu_item_id")
  locale     Locale
  label      String

  menuItem MenuItem @relation(fields: [menuItemId], references: [id], onDelete: Cascade)

  @@unique([menuItemId, locale])
  @@map("menu_item_translations")
}

model Announcement {
  id        Int      @id @default(autoincrement())
  linkUrl   String?  @map("link_url")
  sortOrder Int      @default(0) @map("sort_order")
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  translations AnnouncementTranslation[]

  @@map("announcements")
}

model AnnouncementTranslation {
  id             Int    @id @default(autoincrement())
  announcementId Int    @map("announcement_id")
  locale         Locale
  message        String

  announcement Announcement @relation(fields: [announcementId], references: [id], onDelete: Cascade)

  @@unique([announcementId, locale])
  @@map("announcement_translations")
}

model MarketingReviewCard {
  id        Int      @id @default(autoincrement())
  imageUrl  String   @map("image_url")
  sortOrder Int      @default(0) @map("sort_order")
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  translations MarketingReviewCardTranslation[]

  @@map("marketing_review_cards")
}

model MarketingReviewCardTranslation {
  id      Int     @id @default(autoincrement())
  cardId  Int     @map("card_id")
  locale  Locale
  caption String?

  card MarketingReviewCard @relation(fields: [cardId], references: [id], onDelete: Cascade)

  @@unique([cardId, locale])
  @@map("marketing_review_card_translations")
}

// --- Net Profit (CLAUDE.net-profit.md) --------------------------------
// Ops + intelligence layer over existing Order/Customer/Shipment data, not
// a parallel commerce system. §5.2 Fraud: aggregate courier delivery
// history per phone into a cached risk verdict; FraudSaving logs the ৳
// value protected when a risky COD order is held/blocked.

enum RiskLevel {
  LOW
  MEDIUM
  HIGH
  UNKNOWN
}

model FraudCheck {
  id          Int       @id @default(autoincrement())
  phone       String    @unique // normalized BD MSISDN, +8801XXXXXXXXX
  totalOrders Int       @default(0) @map("total_orders")
  delivered   Int       @default(0)
  cancelled   Int       @default(0) // cancelled + returned, across couriers
  successRate Float?    @map("success_rate") // delivered / totalOrders, null if totalOrders = 0
  riskLevel   RiskLevel @default(UNKNOWN) @map("risk_level")
  breakdown   Json // per-courier raw: { STEADFAST: {...}, PATHAO: {...}, ... }
  source      String // "live" | "cache"
  checkedAt   DateTime  @default(now()) @map("checked_at")
  expiresAt   DateTime  @map("expires_at") // TTL; re-check after this

  @@index([riskLevel])
  @@map("fraud_checks")
}

model FraudSaving {
  id        Int      @id @default(autoincrement())
  orderId   Int?     @map("order_id")
  phone     String
  amount    Decimal  @db.Decimal(10, 2)
  reason    String // "auto_block" | "manual_hold" | "advance_required"
  createdAt DateTime @default(now()) @map("created_at")

  order Order? @relation(fields: [orderId], references: [id], onDelete: SetNull)

  @@index([createdAt])
  @@map("fraud_savings")
}

// --- Net Profit: Blocker (§7.6, M2; extended ADDENDUM §E) ---------------
enum BlockType {
  PHONE
  EMAIL
  IP
  DEVICE
  NAME // matched case-insensitively, exact
  ADDRESS // matched as a normalized substring — mirrors the plugin's address-block behavior
}

enum BlockSource {
  MANUAL
  AUTO
}

model BlockRule {
  id           Int         @id @default(autoincrement())
  type         BlockType
  value        String
  source       BlockSource @default(MANUAL) @map("source")
  category     String? // ADDENDUM §E "blockType": "fraud" | "fake_order" | "repeated_return" — free text,
  // named `category` here since `type` already means "identifier kind" (phone/email/ip/device) in this schema
  customerName String?     @map("customer_name")
  addressText  String?     @map("address_text") // block by delivery address text
  reason       String?
  note         String?
  isActive     Boolean     @default(true) @map("is_active")
  expiresAt    DateTime?   @map("expires_at") // null = permanent
  metadata     Json?
  createdBy    Int?        @map("created_by") // AdminUser.id, no hard relation (matches AuditLog.adminUserId)
  createdAt    DateTime    @default(now()) @map("created_at")

  @@unique([type, value])
  @@index([isActive])
  @@index([source])
  @@index([expiresAt])
  @@map("block_rules")
}

// --- Net Profit: SMS (§7.4, M3) ----------------------------------------
// OTP reuses the existing Otp/OtpPurpose model (already used by B2 auth and
// B6 COD-verification checkout) — no new OTP table.

enum SmsStatus {
  QUEUED
  SENT
  FAILED
}

model SmsTemplate {
  id      Int     @id @default(autoincrement())
  key     String  @unique // "order_placed" | "order_shipped" | "recovery" | ...
  bodyEn  String  @map("body_en")
  bodyBn  String  @map("body_bn")
  enabled Boolean @default(true)

  @@map("sms_templates")
}

model SmsLog {
  id          Int       @id @default(autoincrement())
  to          String
  body        String
  templateKey String?   @map("template_key")
  status      SmsStatus @default(QUEUED)
  provider    String
  cost        Decimal?  @db.Decimal(10, 4)
  meta        Json?
  createdAt   DateTime  @default(now()) @map("created_at")

  @@index([status, createdAt])
  @@map("sms_logs")
}

// --- Net Profit: Advance Payment & Manual Payment (§7.5/§7.12, M4) -----
enum AdvanceStatus {
  PENDING
  PARTIAL
  PAID
  WAIVED
}

model AdvancePayment {
  id        Int           @id @default(autoincrement())
  orderId   Int           @unique @map("order_id")
  required  Decimal       @db.Decimal(10, 2)
  paid      Decimal       @default(0) @db.Decimal(10, 2)
  status    AdvanceStatus @default(PENDING)
  reason    String? // "high_risk" | "manual" | "rule"
  createdAt DateTime      @default(now()) @map("created_at")

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@map("advance_payments")
}

enum ManualPayStatus {
  SUBMITTED
  VERIFIED
  REJECTED
}

model ManualPayment {
  id            Int             @id @default(autoincrement())
  orderId       Int             @map("order_id")
  method        String // "bkash" | "nagad" | "rocket"
  senderMsisdn  String          @map("sender_msisdn")
  trxId         String          @map("trx_id")
  amount        Decimal         @db.Decimal(10, 2)
  screenshotUrl String?         @map("screenshot_url") // proof-of-payment upload (Payments parity)
  status        ManualPayStatus @default(SUBMITTED)
  verifiedBy    Int?            @map("verified_by") // AdminUser.id
  createdAt     DateTime        @default(now()) @map("created_at")

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@unique([method, trxId])
  @@map("manual_payments")
}

// ADDENDUM §J — configuration of each manual method (merchant number,
// account type, EN/BN instructions), deliberately its own surface: distinct
// from the checkout-time gateway selection (PaymentProvider enum) and from
// the verification queue (ManualPayment above).
enum PaymentAccountType {
  PERSONAL
  AGENT
  MERCHANT
}

model PaymentMethodConfig {
  id                     Int                @id @default(autoincrement())
  provider               PaymentProvider    @unique // BKASH | NAGAD | ROCKET | UPAY
  accountType            PaymentAccountType @default(PERSONAL) @map("account_type")
  number                 String
  instructionsEn         String?            @map("instructions_en")
  instructionsBn         String?            @map("instructions_bn")
  iconUrl                String?            @map("icon_url") // logo shown at checkout (Payments parity)
  showIcon               Boolean            @default(true) @map("show_icon")
  // Order.status applied once staff verifies a submission for this method —
  // mirrors the plugin's per-method "order status after payment" setting.
  orderStatusAfterVerify OrderStatus        @default(CONFIRMED) @map("order_status_after_verify")
  isActive               Boolean            @default(true) @map("is_active")
  createdAt              DateTime           @default(now()) @map("created_at")
  updatedAt              DateTime           @updatedAt @map("updated_at")

  @@map("payment_method_configs")
}

// ADDENDUM §K — a labeling/color layer over the existing, real
// `OrderStatus` enum (not a parallel arbitrary-status system a Postgres
// enum can't support without a migration per new value). "Custom order
// statuses with colors" is delivered as: every one of the fixed enum
// values gets an admin-editable EN/BN label, color, and sort order, which
// the order board renders — the achievable, honest reading of "reusing
// Amader's status system underneath."
model OrderStatusConfig {
  id        Int         @id @default(autoincrement())
  status    OrderStatus @unique
  labelEn   String      @map("label_en")
  labelBn   String      @map("label_bn")
  color     String // hex, e.g. "#22b07d"
  sortOrder Int         @default(0) @map("sort_order")

  @@map("order_status_configs")
}

// --- Net Profit: Incomplete/Abandoned Order Recovery (§7.7, M5) --------
model IncompleteOrder {
  id               Int      @id @default(autoincrement())
  cartId           Int?     @unique @map("cart_id") // lets the cart.updated listener upsert idempotently per cart
  customerId       Int?     @map("customer_id")
  phone            String?
  email            String?
  cart             Json // snapshot of items
  subtotal         Decimal  @db.Decimal(10, 2)
  stage            String // "cart" | "checkout" | "payment"
  recovered        Boolean  @default(false)
  recoveredOrderId Int?     @map("recovered_order_id") // soft reference, no relation (order created independently)
  recoveryAttempts Int      @default(0) @map("recovery_attempts")
  lastSeenAt       DateTime @default(now()) @map("last_seen_at")
  createdAt        DateTime @default(now()) @map("created_at")

  campaignQueue CartCampaignQueue[]

  @@index([recovered, lastSeenAt])
  @@map("incomplete_orders")
}

// --- Net Profit: Cart Abandonment campaign engine (ADDENDUM §C) --------
// A separate, automated, multi-channel, multi-step, scheduled win-back
// engine — distinct from the manual Incomplete Orders recovery above.
// `CartCampaignQueue` is the scheduler/worker table.
enum CampaignChannel {
  EMAIL
  SMS
}

enum DelayUnit {
  MINUTE
  HOUR
  DAY
}

enum CampaignStatus {
  ACTIVE
  PAUSED
}

enum QueueStatus {
  PENDING
  SENT
  FAILED
  SKIPPED
}

model CartCampaignTemplate {
  id         Int             @id @default(autoincrement())
  channel    CampaignChannel
  name       String
  subject    String? // email only
  bodyEn     String          @map("body_en")
  bodyBn     String          @map("body_bn")
  delayValue Int             @default(30) @map("delay_value") // fire this long after abandonment
  delayUnit  DelayUnit       @default(MINUTE) @map("delay_unit")
  status     CampaignStatus  @default(ACTIVE)
  createdAt  DateTime        @default(now()) @map("created_at")
  updatedAt  DateTime        @updatedAt @map("updated_at")

  queue CartCampaignQueue[]

  @@map("cart_campaign_templates")
}

model CartCampaignQueue {
  id           Int             @id @default(autoincrement())
  incompleteId Int             @map("incomplete_id")
  templateId   Int             @map("template_id")
  channel      CampaignChannel
  recipient    String?
  status       QueueStatus     @default(PENDING)
  attempts     Int             @default(0)
  scheduledAt  DateTime        @map("scheduled_at") // when it becomes due
  lockedAt     DateTime?       @map("locked_at") // worker claim lock (prevents double-send)
  processedAt  DateTime?       @map("processed_at")
  lastError    String?         @map("last_error")
  createdAt    DateTime        @default(now()) @map("created_at")
  updatedAt    DateTime        @updatedAt @map("updated_at")

  incompleteOrder IncompleteOrder      @relation(fields: [incompleteId], references: [id], onDelete: Cascade)
  template        CartCampaignTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@unique([incompleteId, templateId, channel]) // never enqueue the same step twice
  @@index([status, scheduledAt])
  @@map("cart_campaign_queue")
}

model CartCampaignLog {
  id           Int             @id @default(autoincrement())
  incompleteId Int             @map("incomplete_id")
  templateId   Int?            @map("template_id")
  channel      CampaignChannel
  recipient    String?
  subject      String?
  message      String
  status       String
  responseCode String?         @map("response_code")
  responseMsg  String?         @map("response_msg")
  sentAt       DateTime        @default(now()) @map("sent_at")

  @@index([incompleteId])
  @@map("cart_campaign_logs")
}

// --- Net Profit: Profit Manager (§7.10, M6) -----------------------------
// Landed cost input reuses the existing Product.costPerItem column — no new
// ProductCost table needed (confirmed by reading the real B1 schema before
// building this).
model OrderProfit {
  id               Int      @id @default(autoincrement())
  orderId          Int      @unique @map("order_id")
  revenue          Decimal  @db.Decimal(10, 2)
  cogs             Decimal  @db.Decimal(10, 2)
  shipping         Decimal  @default(0) @db.Decimal(10, 2)
  fees             Decimal  @default(0) @db.Decimal(10, 2) // gateway/courier fees
  adSpend          Decimal  @default(0) @map("ad_spend") @db.Decimal(10, 2) // optional manual attribution
  netProfit        Decimal  @map("net_profit") @db.Decimal(10, 2)
  // True when any line item's COGS used the fallback-profit estimate
  // (Profit parity) rather than a real Product/ProductVariant.costPerItem —
  // flags the number as an estimate instead of silently treating an unset
  // cost as ৳0.
  hasEstimatedCost Boolean  @default(false) @map("has_estimated_cost")
  computedAt       DateTime @default(now()) @map("computed_at")

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([computedAt])
  @@map("order_profits")
}

// ADDENDUM §D — a day-level marketing-cost ledger, separate from
// OrderProfit's per-order manual `adSpend` field above. The carry-forward
// cron copies yesterday's row into today when the admin forgets to enter one.
model MarketingCost {
  id          Int      @id @default(autoincrement())
  costDate    DateTime @unique @map("cost_date") @db.Date
  adsCost     Decimal  @default(0) @map("ads_cost") @db.Decimal(12, 2)
  otherCost   Decimal  @default(0) @map("other_cost") @db.Decimal(12, 2)
  note        String?
  autoCarried Boolean  @default(false) @map("auto_carried")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("marketing_costs")
}

// ADDENDUM §D — day-level roll-up the dashboards (Overview KPI, Profit
// report) actually read, rebuilt by a daily cron from completed orders'
// OrderProfit rows plus MarketingCost.
model DailyProfitCache {
  id            Int      @id @default(autoincrement())
  reportDate    DateTime @unique @map("report_date") @db.Date
  totalRevenue  Decimal  @default(0) @map("total_revenue") @db.Decimal(12, 2)
  totalBuyCost  Decimal  @default(0) @map("total_buy_cost") @db.Decimal(12, 2)
  totalAdsCost  Decimal  @default(0) @map("total_ads_cost") @db.Decimal(12, 2)
  totalOther    Decimal  @default(0) @map("total_other") @db.Decimal(12, 2)
  totalShipping Decimal  @default(0) @map("total_shipping") @db.Decimal(12, 2)
  netProfit     Decimal  @default(0) @map("net_profit") @db.Decimal(12, 2)
  orderCount    Int      @default(0) @map("order_count")
  computedAt    DateTime @default(now()) @map("computed_at")

  @@index([reportDate])
  @@map("daily_profit_cache")
}

// --- Net Profit: Accounts (§12 — expense/due/VAT/cash-flow) ---------------
// VAT rate/BIN live in the generic Setting store via NetProfitSettingsService
// (namespace "accounts", same pattern as every other Net Profit sub-feature)
// — no dedicated settings table needed for a couple of scalar fields.

// Category is free text (not an enum) — same reasoning as BlockRule.category:
// an admin should be able to add "Warehouse Rent" without a migration. The
// admin UI seeds a dropdown with common e-commerce categories as a starting
// point, not a closed set.
model Expense {
  id          Int      @id @default(autoincrement())
  expenseDate DateTime @map("expense_date") @db.Date
  category    String
  amount      Decimal  @db.Decimal(12, 2)
  // Counts as input VAT (Mushak) in the VAT summary when true — e.g. VAT
  // paid on a supplier invoice, as opposed to a salary/rent line that has
  // no VAT component.
  isVatInput  Boolean  @default(false) @map("is_vat_input")
  note        String?
  createdBy   Int?     @map("created_by")
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([expenseDate])
  @@map("expenses")
}

enum DuePartyType {
  CUSTOMER
  SUPPLIER
}

enum DueStatus {
  PENDING
  PARTIALLY_PAID
  PAID
}

// A due book (বাকি খাতা) entry — money the business is owed (CUSTOMER, e.g.
// a credit sale) or owes (SUPPLIER, e.g. a restock invoice on credit). No
// Purchase/Vendor module exists yet (out of scope, see AGENTS.finalize.md
// §9), so `partyName` is free text for suppliers; `customerId` links a real
// Customer record when the party is a known storefront customer.
model Due {
  id         Int          @id @default(autoincrement())
  partyType  DuePartyType @map("party_type")
  partyName  String       @map("party_name")
  customerId Int?         @map("customer_id")
  amount     Decimal      @db.Decimal(12, 2)
  paidAmount Decimal      @default(0) @map("paid_amount") @db.Decimal(12, 2)
  status     DueStatus    @default(PENDING)
  dueDate    DateTime?    @map("due_date") @db.Date
  note       String?
  createdBy  Int?         @map("created_by")
  createdAt  DateTime     @default(now()) @map("created_at")
  updatedAt  DateTime     @updatedAt @map("updated_at")

  customer Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)

  @@index([status])
  @@index([partyType])
  @@map("dues")
}
